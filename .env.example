# Clitronic Environment Variables
# Copy this file to .env.local and fill in your values

# Required: Anthropic API key for Claude AI
# Alternative: Use Claude Code authentication (automatic if Claude Code installed)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: OpenAI API key for voice mode (speech-to-text with Whisper)
# Without this, voice mode will not be available
OPENAI_API_KEY=your_openai_api_key_here
