# Clitronic web app configuration
# Copy this file to .env.local and adjust values.

# Required: OpenAI API key used by:
# - /api/chat (structured card generation)
# - /api/realtime/session (ephemeral realtime sessions)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Brave Search API key for higher quality image results.
# If omitted, image search falls back to Wikimedia Commons only.
BRAVE_API_KEY=your_brave_api_key_here

# Optional: per-IP daily rate limit for /api/chat (default: 20)
DAILY_RATE_LIMIT=20
