# Clitronic web app configuration
# Copy this file to .env.local and adjust values.

# Required: OpenAI API key used by:
# - /api/chat (structured card generation)
# - /api/realtime/session (ephemeral realtime sessions)
# - /api/speech (exact-text TTS)
OPENAI_API_KEY=

# Optional: long random HMAC key for stable, non-enumerable Realtime safety identifiers.
# If omitted, OPENAI_API_KEY is used. Keep this server-only.
OPENAI_SAFETY_ID_SECRET=

# Optional: Brave Search API key for higher quality image results.
# If omitted, image search falls back to Wikimedia Commons only.
BRAVE_API_KEY=

# Optional: per-IP daily rate limit for /api/chat (default: 20)
DAILY_RATE_LIMIT=20

# Optional: per-process, demo-friendly abuse controls for unauthenticated helper endpoints.
# REALTIME_SESSION_* limits client-secret mint requests, not session duration or spend.
REALTIME_SESSION_MINUTE_LIMIT=12
REALTIME_SESSION_DAILY_LIMIT=120
IMAGE_SEARCH_MINUTE_LIMIT=30
IMAGE_SEARCH_DAILY_LIMIT=300
IMAGE_PROXY_MINUTE_LIMIT=120
IMAGE_PROXY_DAILY_LIMIT=1000
