# Clitronic Environment Variables
# Copy this file to .env.local and fill in your values

# Optional fallback: Anthropic credentials for Claude provider
# Not required if users authenticate via local Claude Code credentials
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_AUTH_TOKEN=your_anthropic_bearer_token_here

# Optional fallback: OpenAI credentials for Codex provider and voice transcription
# Not required if users authenticate via local OpenAI Codex credentials
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_ACCESS_TOKEN=your_openai_bearer_token_here
