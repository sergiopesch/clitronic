# Clitronic local model configuration
# Copy this file to .env.local and adjust if needed.

# Optional explicit local GGUF path.
# If set, Clitronic loads this file directly.
# LOCAL_LLM_MODEL_PATH=/absolute/path/to/your-model.gguf

# Optional model URI for auto-resolution / auto-download via node-llama-cpp.
# If neither MODEL_PATH nor MODEL_URI is set, Clitronic defaults to:
# hf:Qwen/Qwen2.5-1.5B-Instruct-GGUF:qwen2.5-1.5b-instruct-q4_k_m.gguf
# LOCAL_LLM_MODEL_URI=hf:Qwen/Qwen2.5-1.5B-Instruct-GGUF:qwen2.5-1.5b-instruct-q4_k_m.gguf

# Optional override for the node-llama-cpp model cache directory.
# If omitted, node-llama-cpp uses its default global cache under ~/.node-llama-cpp/models
# LOCAL_LLM_MODELS_DIR=/absolute/path/to/model-cache

# Optional generation tuning.
# LOCAL_LLM_MAX_TOKENS=512
# LOCAL_LLM_TEMPERATURE=0.7
